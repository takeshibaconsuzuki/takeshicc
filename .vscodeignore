.vscode/**
.vscode-test/**
.claude/**
src/**
test/**
out/**
.node/**
.gitignore
.gitattributes
.eslintrc.*
esbuild.js
tsconfig.json
vitest.config.*
package-lock.json
**/*.map
**/*.ts
**/tsconfig*.json
*.vsix
CLAUDE.md
CLAUDE.local.md
!dist/**

# Block all of node_modules by default. The bundle in dist/extension.js
# already inlines pure-JS deps via esbuild; the only modules we still need
# to ship are the externals marked in esbuild.js (sql.js).
node_modules/**

# sql.js — pure-JS SQLite via WASM, used to read/write workspace state.vscdb.
!node_modules/sql.js/dist/sql-wasm.js
!node_modules/sql.js/dist/sql-wasm.wasm
!node_modules/sql.js/package.json
