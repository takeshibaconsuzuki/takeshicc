.vscode/**
.vscode-test/**
.claude/**
src/**
test/**
out/**
.node/**
.gitignore
.gitattributes
.eslintrc.*
esbuild.js
tsconfig.json
vitest.config.*
package-lock.json
**/*.map
**/*.ts
**/tsconfig*.json
*.vsix
CLAUDE.md
CLAUDE.local.md
!dist/**

# Block all of node_modules by default. The bundle in dist/extension.js
# already inlines pure-JS deps via esbuild; the only modules we need to
# ship are the native ones marked external in esbuild.js (tree-sitter*,
# @lancedb/lancedb), plus their runtime transitive deps. Re-include those
# explicitly.
node_modules/**
!node_modules/tree-sitter/**
!node_modules/tree-sitter-c-sharp/**
!node_modules/tree-sitter-cpp/**
!node_modules/tree-sitter-go/**
!node_modules/tree-sitter-java/**
!node_modules/tree-sitter-javascript/**
!node_modules/tree-sitter-python/**
!node_modules/tree-sitter-rust/**
!node_modules/tree-sitter-scala/**
!node_modules/tree-sitter-typescript/**
!node_modules/node-addon-api/**
!node_modules/node-gyp-build/**

# LanceDB runtime: the JS wrapper, a runtime dep (reflect-metadata), and
# the platform-specific native binary. npm only installs the native
# package matching the host arch (optionalDependencies), so the .vsix is
# necessarily host-arch-only — repackage on each target platform.
!node_modules/@lancedb/lancedb/**
!node_modules/@lancedb/lancedb-darwin-arm64/**
!node_modules/@lancedb/lancedb-darwin-x64/**
!node_modules/@lancedb/lancedb-linux-x64-gnu/**
!node_modules/@lancedb/lancedb-linux-x64-musl/**
!node_modules/@lancedb/lancedb-linux-arm64-gnu/**
!node_modules/@lancedb/lancedb-linux-arm64-musl/**
!node_modules/@lancedb/lancedb-win32-x64-msvc/**
!node_modules/@lancedb/lancedb-win32-arm64-msvc/**
!node_modules/reflect-metadata/**

# apache-arrow is lancedb's peer dependency. Its main entrypoint pulls
# in `tslib` and `flatbuffers` at runtime; the `bin/arrow2csv.js` CLI
# requires `command-line-args`/`command-line-usage`/`json-bignum`, but
# nothing in the lancedb path loads it, so we drop bin/ to avoid
# shipping those transitive deps.
!node_modules/apache-arrow/**
node_modules/apache-arrow/bin/**
!node_modules/tslib/**
!node_modules/flatbuffers/**

# Within the tree-sitter packages, node-gyp-build loads from prebuilds/
# at runtime, so the C parser sources, build configs, and grammar JSON
# are not needed in the .vsix. Strip them to keep package size sane.
node_modules/tree-sitter-*/src/**
node_modules/tree-sitter-*/typescript/src/**
node_modules/tree-sitter-*/tsx/src/**
node_modules/tree-sitter-*/grammar.js
node_modules/tree-sitter-*/binding.gyp
node_modules/tree-sitter-*/queries/**
node_modules/tree-sitter-*/common/**
node_modules/tree-sitter-*/*.wasm
node_modules/tree-sitter-*/tree-sitter.json

# Generic prune of doc/test/CI noise inside any included node_modules dir.
node_modules/**/*.md
node_modules/**/CHANGELOG*
node_modules/**/.github/**
node_modules/**/.npmignore
node_modules/**/test/**
node_modules/**/tests/**
node_modules/**/__tests__/**
node_modules/**/example/**
node_modules/**/examples/**
node_modules/**/docs/**
