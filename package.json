{
  "name": "takeshicc",
  "displayName": "Takeshi CC",
  "description": "Quickly send file references to Claude Code in your terminal, and browse past sessions.",
  "version": "0.0.1",
  "publisher": "takeshi",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/takeshibaconsuzuki/takeshicc.git"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "takeshicc.insertReference",
        "title": "Takeshi CC: Insert File Reference"
      },
      {
        "command": "takeshicc.openSession",
        "title": "Takeshi CC: Open Session"
      },
      {
        "command": "takeshicc.refreshSessions",
        "title": "Takeshi CC: Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "takeshicc.newChat",
        "title": "Takeshi CC: New Chat",
        "icon": "$(add)"
      }
    ],
    "keybindings": [
      {
        "command": "takeshicc.insertReference",
        "key": "alt+k",
        "mac": "alt+k",
        "when": "editorTextFocus"
      },
      {
        "command": "runCommands",
        "key": "ctrl+`",
        "mac": "ctrl+`",
        "args": {
          "commands": [
            "workbench.action.terminal.toggleTerminal",
            "workbench.action.toggleMaximizedPanel"
          ]
        },
        "when": "!panelVisible"
      },
      {
        "command": "runCommands",
        "key": "ctrl+`",
        "mac": "ctrl+`",
        "args": {
          "commands": [
            "workbench.action.toggleMaximizedPanel",
            "workbench.action.closePanel"
          ]
        },
        "when": "panelVisible && panelMaximized"
      },
      {
        "command": "workbench.action.toggleMaximizedPanel",
        "key": "ctrl+`",
        "mac": "ctrl+`",
        "when": "panelVisible && !panelMaximized"
      },
      {
        "command": "workbench.action.terminal.sendSequence",
        "key": "pageup",
        "mac": "pageup",
        "args": {
          "text": "\u001b[5~"
        },
        "when": "terminalFocus"
      },
      {
        "command": "workbench.action.terminal.sendSequence",
        "key": "pagedown",
        "mac": "pagedown",
        "args": {
          "text": "\u001b[6~"
        },
        "when": "terminalFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "takeshicc",
          "title": "Takeshi CC",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "takeshicc": [
        {
          "id": "takeshicc.sessions",
          "name": "Sessions"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "takeshicc.newChat",
          "when": "view == takeshicc.sessions",
          "group": "navigation@1"
        },
        {
          "command": "takeshicc.refreshSessions",
          "when": "view == takeshicc.sessions",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Takeshi CC",
      "properties": {
        "takeshicc.embedding.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "API key for the OpenAI-compatible embedding endpoint used by `claude-context` indexing/search tools. Stored in VS Code settings — consider using a settings sync exclusion or a workspace-only override for shared machines.",
          "scope": "machine-overridable"
        },
        "takeshicc.embedding.baseURL": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "markdownDescription": "Base URL of the OpenAI-compatible embedding endpoint (e.g. `https://api.openai.com/v1`, `http://localhost:11434/v1` for Ollama)."
        },
        "takeshicc.embedding.model": {
          "type": "string",
          "default": "text-embedding-3-small",
          "markdownDescription": "Embedding model name (e.g. `text-embedding-3-small`, `text-embedding-3-large`, or any model your OpenAI-compatible endpoint exposes)."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "vsix": "npm run package && vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@zilliz/claude-context-core": "^0.1.11"
  }
}
