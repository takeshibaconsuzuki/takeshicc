{
  "name": "takeshicc",
  "displayName": "Takeshi CC",
  "description": "Quickly send file references to Claude Code in your terminal, and browse past sessions.",
  "version": "0.0.1",
  "publisher": "takeshi",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/takeshibaconsuzuki/takeshicc.git"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "takeshicc.insertReference",
        "title": "Takeshi CC: Insert File Reference"
      },
      {
        "command": "takeshicc.openSession",
        "title": "Takeshi CC: Open Session"
      },
      {
        "command": "takeshicc.refreshSessions",
        "title": "Takeshi CC: Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "takeshicc.newChat",
        "title": "Takeshi CC: New Chat",
        "icon": "$(add)"
      },
      {
        "command": "takeshicc.applyLayoutSizes",
        "title": "Takeshi CC: Apply Layout Sizes"
      }
    ],
    "keybindings": [
      {
        "command": "takeshicc.insertReference",
        "key": "alt+k",
        "mac": "alt+k",
        "when": "editorTextFocus"
      },
      {
        "command": "workbench.action.terminal.toggleTerminal",
        "key": "ctrl+`",
        "mac": "ctrl+`",
        "when": "!panelVisible"
      },
      {
        "command": "workbench.action.toggleMaximizedPanel",
        "key": "ctrl+`",
        "mac": "ctrl+`",
        "when": "panelVisible"
      },
      {
        "command": "workbench.action.terminal.sendSequence",
        "key": "pageup",
        "mac": "pageup",
        "args": {
          "text": "\u001b[5~"
        },
        "when": "terminalFocus"
      },
      {
        "command": "workbench.action.terminal.sendSequence",
        "key": "pagedown",
        "mac": "pagedown",
        "args": {
          "text": "\u001b[6~"
        },
        "when": "terminalFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "takeshicc",
          "title": "Takeshi CC",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "takeshicc": [
        {
          "id": "takeshicc.sessions",
          "name": "Sessions",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "takeshicc.refreshSessions",
          "when": "view == takeshicc.sessions",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Takeshi CC",
      "properties": {
        "takeshicc.sessions.tailLines": {
          "type": "integer",
          "default": 2,
          "minimum": 0,
          "maximum": 10,
          "markdownDescription": "Number of lines of the most recent message to show under each session title in the sidebar. `0` hides the tail entirely. The tail is refreshed on the slow auto-refresh tick (~30s), not on every hook event."
        },
        "takeshicc.layout.sidebarSizePx": {
          "type": "integer",
          "default": 480,
          "minimum": 0,
          "markdownDescription": "Sidebar width in pixels written to VS Code's global `state.vscdb` (key `workbench.sideBar.size`) when running `Takeshi CC: Apply Layout Sizes`. Requires a window reload."
        },
        "takeshicc.layout.panelSizePx": {
          "type": "integer",
          "default": 640,
          "minimum": 0,
          "markdownDescription": "Panel width (or height, when on bottom/top) in pixels written to VS Code's global `state.vscdb` (key `workbench.panel.size`) when running `Takeshi CC: Apply Layout Sizes`. Requires a window reload."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "vsix": "npm run package && vsce package"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "@types/sql.js": "^1.4.11",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fs-extra": "^11.3.4",
    "sql.js": "^1.14.1"
  }
}
